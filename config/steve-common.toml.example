[ai]
    # AI provider to use: groq, openai, or gemini
    provider = "groq"

[openai]
    # API key for the selected provider. Do not commit real keys.
    apiKey = ""

    # Model name for the selected provider
    model = "gpt-4-turbo-preview"

    # Maximum tokens per API request
    maxTokens = 8000

    # Temperature (0.0-2.0, lower is more deterministic)
    temperature = 0.7

[behavior]
    # Ticks between action checks (20 ticks = 1 second)
    actionTickDelay = 20

    # Allow Steves to respond in chat
    enableChatResponses = true

    # Maximum number of Steves that can be active simultaneously
    maxActiveSteves = 10

[minemind]
    # All MineMind features are disabled by default
    autonomousModeDefault = false
    enableChatGuidance = false
    enableCommunityMode = false
    enableLongTermMemory = false

    # 20 ticks = 1 second
    thinkIntervalTicks = 200

    # Maximum task steps a MineMind planner may emit
    maxPlanningSteps = 3

    # Keep false until the safe LLM planner phase is implemented
    useLlmPlanner = false

    # Minimum ticks between MineMind chat replies from the same Steve
    chatResponseCooldownTicks = 100
